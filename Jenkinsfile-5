pipeline {
    agent any

    stages {
        // 前面必须有构建、测试阶段
        stage('Build') {
            steps {
                echo "✅ 构建成功"
            }
        }

        stage('Test') {
            steps {
                echo "✅ 测试成功"
            }
        }

        // 重点：只有前面成功，才会执行这里
        stage('Deploy') {
            when {
              expression {
                currentBuild.result == null || currentBuild.result == 'SUCCESS'
              }
            }
            steps {
                // 用 echo 模拟部署，不报错
                echo "✅ 部署成功（模拟 make publish）"
            }
        }
    }
}
