pipeline {
    agent any
    stages {
        stage('Test') {
            steps {
                sh 'make check'
            }
        }
    }
    post {
        always {
            junit '**/target/*.xml'
        }
        failure {
            mail to: '2233023428@qq.com', subject: 'The Pipeline failed :(', body: '您的Jenkins构建失败了，请查看日志！'
        }
    }
}
